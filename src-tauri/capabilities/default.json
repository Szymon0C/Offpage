{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "llama-server" }]
    }
  ]
}
